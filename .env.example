# Frontend (Vite) — prefix with VITE_ to expose to the browser
# Override the API base URL (leave empty to use the Vite dev proxy)
VITE_API_BASE_URL=

# Backend (server/)
# Port the API server listens on (default: 4001; use 0 for OS-assigned)
PORT=4001

# Comma-separated list of allowed CORS origins
# Defaults to http://localhost:5173,http://localhost:4173 in development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
